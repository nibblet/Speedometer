{
  "expo": {
    "name": "Cart Speedo",
    "slug": "cart-speedo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "bundleIdentifier": "com.paulcobb.cartspeedo",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to display your speed, heading, and trip distance on the speedometer."
      }
    },
    "android": {
      "package": "com.paulcobb.cartspeedo",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Used to display your speed, heading, and trip distance."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "03f2de95-cd2d-4b23-86b7-23f54dfcf813"
      }
    }
  }
}
